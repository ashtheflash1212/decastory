# Supabase (free tier) — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider — set which one to use. "gemini" is free (see README).
AI_PROVIDER=gemini

# Google AI Studio (free tier) — https://ai.google.dev -> Get API Key
GEMINI_API_KEY=your-gemini-key

# Optional: only needed if you later switch AI_PROVIDER to "anthropic" (paid, pay-per-token)
ANTHROPIC_API_KEY=
